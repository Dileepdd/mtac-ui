{
  "info": {
    "_postman_id": "mtac-api-collection",
    "name": "MTAC API",
    "description": "MTAC Project Management API \u2014 workspaces, projects, tasks, RBAC.\n\nRun requests in order within each folder to auto-populate collection variables.\n\nNOTE: JSON bodies use // comments for documentation. Remove commented lines before sending.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",            // required | min 3 chars\n  \"email\": \"testuser@example.com\", // required\n  \"password\": \"Password@123\"       // required | min 8 chars, must contain uppercase, lowercase, number, special char\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Success flag is true\", () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\", // required\n  \"password\": \"Password@123\"       // required\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"Has tokens\", () => {",
                  "  pm.expect(json.data.accessToken).to.be.a(\"string\");",
                  "  pm.expect(json.data.refreshToken).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.environment.set(\"accessToken\", json.data.accessToken);",
                  "pm.environment.set(\"refreshToken\", json.data.refreshToken);",
                  "console.log(\"accessToken saved:\", json.data.accessToken.substring(0, 20) + \"...\");"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\" // required\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"Has new access token\", () => pm.expect(json.data.accessToken).to.be.a(\"string\"));",
                  "",
                  "pm.environment.set(\"accessToken\", json.data.accessToken);",
                  "console.log(\"accessToken refreshed:\", json.data.accessToken.substring(0, 20) + \"...\");"
                ]
              }
            }
          ]
        }
      ]
    },
