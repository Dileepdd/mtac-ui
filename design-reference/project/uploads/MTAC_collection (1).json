              "mode": "raw",
              "raw": "{\n  \"permissions\": [         // required | array, min 1 item\n    // --- Workspace ---\n    // \"VIEW_WORKSPACE\",    // view workspace details\n    // \"UPDATE_WORKSPACE\",  // update workspace settings\n    // \"DELETE_WORKSPACE\",  // delete the workspace\n    // --- Members ---\n    // \"ADD_MEMBER\",        // add a new member to workspace\n    // \"REMOVE_MEMBER\",     // remove a member from workspace\n    // \"VIEW_MEMBERS\",      // list all workspace members\n    // \"UPDATE_MEMBER_ROLE\",// change a member's role\n    // --- Roles ---\n    // \"ASSIGN_ROLE\",       // assign a role when adding/updating a member\n    // \"CHANGE_ROLE\",       // modify role permissions\n    // --- Projects ---\n    // \"CREATE_PROJECT\",    // create a project\n    // \"VIEW_PROJECT\",      // view project details\n    // \"UPDATE_PROJECT\",    // update a project\n    // \"DELETE_PROJECT\",    // delete a project\n    // --- Tasks ---\n    // \"CREATE_TASK\",       // create a task\n    // \"VIEW_TASK\",         // view task details\n    // \"UPDATE_TASK\",       // update a task\n    // \"DELETE_TASK\",       // delete a task\n    // \"ASSIGN_TASK\"        // assign a task to a member\n    \"VIEW_WORKSPACE\",\n    \"VIEW_MEMBERS\",\n    \"VIEW_PROJECT\",\n    \"VIEW_TASK\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
